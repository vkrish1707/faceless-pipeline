{
  "name": "faceless-pipeline",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @studio/app dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:claude": "pnpm tsx scripts/smoke/claude-hello.ts",
    "smoke:pexels": "pnpm tsx scripts/smoke/pexels-hello.ts",
    "smoke:piper": "pnpm tsx scripts/smoke/piper-hello.ts",
    "smoke:whisper": "pnpm tsx scripts/smoke/whisper-hello.ts",
    "smoke:remotion": "pnpm tsx scripts/smoke/remotion-hello.ts",
    "smoke:phase1": "pnpm tsx scripts/smoke/phase1-hello.ts",
    "smoke:phase2": "pnpm tsx scripts/smoke/phase2-hello.ts",
    "smoke:all": "pnpm smoke:claude && pnpm smoke:pexels && pnpm smoke:piper && pnpm smoke:whisper && pnpm smoke:remotion",
    "setup:piper": "bash scripts/setup/install-piper.sh",
    "setup:whisper": "bash scripts/setup/install-whisper.sh",
    "db:generate": "pnpm --filter @studio/app exec prisma generate",
    "db:migrate": "pnpm --filter @studio/app exec prisma migrate dev",
    "db:studio": "pnpm --filter @studio/app exec prisma studio"
  },
  "devDependencies": {
    "@remotion/renderer": "^4.0.463",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@remotion/bundler": "^4.0.463",
    "@remotion/cli": "^4.0.463",
    "dotenv": "^17.4.2",
    "remotion": "^4.0.463"
  }
}
