generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../../../data/studio.db"
}

model Book {
  id        String    @id @default(cuid())
  title     String
  filePath  String
  niche     String
  pageCount Int
  status    String
  createdAt DateTime  @default(now())
  chapters  Chapter[]
}

model Chapter {
  id          String       @id @default(cuid())
  bookId      String
  book        Book         @relation(fields: [bookId], references: [id])
  title       String
  orderIndex  Int
  startPage   Int
  endPage     Int
  rawText     String
  status      String
  ideas       Idea[]
  suggestions Suggestion[]
}

model Idea {
  id              String   @id @default(cuid())
  chapterId       String
  chapter         Chapter  @relation(fields: [chapterId], references: [id])
  title           String
  summary         String
  targetLengthSec Int
  score           Int?
  scoreBreakdown  Json?
  trendSignals    Json?
  flags           Json?
  seriesId        String?
  status          String
  sourceQuotes    Json?
  candidateHooks  Json?
  script          Script?
}

model Script {
  id             String    @id @default(cuid())
  ideaId         String    @unique
  idea           Idea      @relation(fields: [ideaId], references: [id])
  hook           String
  body           String
  cta            String
  visualBeats    Json
  metadata       Json
  score          Int?
  scoreBreakdown Json?
  status         String
  warnings       Json?
  approvedAt     DateTime?
  generatedAt    DateTime?
  lastEditedAt   DateTime?
  render         Render?
  assets         Asset[]
}

model Asset {
  id          String    @id @default(cuid())
  scriptId    String?
  script      Script?   @relation(fields: [scriptId], references: [id])
  beatIndex   Int?
  type        String
  sourceUrl   String?
  localPath   String
  thumbPath   String?
  keyword     String?
  durationSec Float?
  width       Int?
  height      Int?
  pickedAt    DateTime?

  @@index([scriptId, beatIndex])
}

model PexelsCache {
  id        String   @id @default(cuid())
  queryKey  String   @unique
  results   Json
  fetchedAt DateTime @default(now())
}

model Render {
  id           String    @id @default(cuid())
  scriptId     String    @unique
  script       Script    @relation(fields: [scriptId], references: [id])
  audioPath    String?
  captionsPath String?
  videoPath    String?
  metadataPath String?
  musicPath    String?
  durationSec  Float?
  fileSizeMB   Float?
  status       String
  progress     Int       @default(0)
  error        String?
  warning      String?
  startedAt    DateTime?
  completedAt  DateTime?
}

// Setting is a generic key/value store. Phase 4 introduced "default_voice".
// Phase 7 adds the following lazily-inserted keys (no schema change):
//   - "enable_music"        ("true" | "false", default "false")
//   - "render_concurrency"  ("1".."4", default "2")
//   - "music_gain_db"       integer string, default "-18"
//   - "log_level"           ("debug" | "info" | "warn" | "error", default "info")
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Suggestion {
  id         String    @id @default(cuid())
  chapterId  String
  chapter    Chapter   @relation(fields: [chapterId], references: [id])
  kind       String
  payload    Json
  reason     String
  status     String
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([chapterId, status])
}

model TrendSnapshot {
  id        String   @id @default(cuid())
  keyword   String
  source    String
  data      Json
  fetchedAt DateTime @default(now())

  @@unique([keyword, source])
}

model ApiUsage {
  id                 String   @id @default(cuid())
  service            String
  endpoint           String
  tokensIn           Int?
  tokensOut          Int?
  cacheTokensRead    Int?
  cacheTokensCreated Int?
  costUsd            Float?
  traceId            String?
  createdAt          DateTime @default(now())
}

model Job {
  id          String    @id @default(cuid())
  type        String
  status      String
  progress    Int       @default(0)
  error       String?
  targetType  String
  targetId    String
  payload     Json?
  result      Json?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([targetType, targetId, type])
  @@index([status])
}
